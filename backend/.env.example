# PORT: The port the backend server will listen on. (Cloud hosts like Render set this automatically)
PORT=5050

# MONGODB_URI: Your MongoDB Atlas Cloud Database connection string.
# Replace <username>, <password>, and <cluster-url> with your Atlas details.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/milkapp?retryWrites=true&w=majority
